generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(USER)
  googleRefresh String?
  msRefresh     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  saves         Save[]
  sessions      Session[]
}

model Session {
  id          String   @id @default(uuid())
  status      String   @default("PENDING")
  deviceToken String?  @unique
  userId      String?
  
  deviceName  String?
  sdTotal     String?
  sdFree      String?
  nandTotal   String?
  nandFree    String?

  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model Save {
  id          String   @id @default(uuid())
  filename    String
  gameTitle   String?
  description String?
  filePath    String
  fileSize    Int
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}
